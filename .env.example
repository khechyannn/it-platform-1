PORT=3000
NODE_ENV=development

# Local (after npm run setup:db):
DATABASE_URL=postgres://platform:platform@localhost:5432/it_platform
# Docker Compose (postgres exposed on 5433):
# DATABASE_URL=postgres://platform:platform@localhost:5433/it_platform
REDIS_URL=redis://localhost:6379

# Shared secret for GitHub webhook signature verification (X-Hub-Signature-256)
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# JWT for login sessions
JWT_SECRET=your-random-jwt-secret-min-32-chars
